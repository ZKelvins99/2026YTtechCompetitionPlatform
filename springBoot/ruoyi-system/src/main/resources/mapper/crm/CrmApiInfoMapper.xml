<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.crm.mapper.CrmApiInfoMapper">

    <resultMap type="com.ruoyi.system.crm.domain.CrmApiInfo" id="CrmApiInfoResult">
        <result property="id" column="id"/>
        <result property="apiName" column="api_name"/>
        <result property="apiDesc" column="api_desc"/>
        <result property="apiUrl" column="api_url"/>
        <result property="apiMethod" column="api_method"/>
        <result property="requestExample" column="request_example"/>
        <result property="responseExample" column="response_example"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectVo">
        select id, api_name, api_desc, api_url, api_method, request_example, response_example,
               status, create_by, create_time, update_time
        from crm_api_info
    </sql>

    <select id="selectCrmApiInfoById" resultMap="CrmApiInfoResult">
        <include refid="selectVo"/> where id = #{id}
    </select>

    <select id="selectCrmApiInfoByUrlAndMethod" resultMap="CrmApiInfoResult">
        <include refid="selectVo"/>
        where api_url = #{apiUrl} and upper(api_method) = upper(#{apiMethod})
    </select>

    <select id="selectCrmApiInfoList" resultMap="CrmApiInfoResult">
        <include refid="selectVo"/>
        <where>
            <if test="apiName != null and apiName != ''">
                AND api_name like concat(concat('%', #{apiName}), '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="apiMethod != null and apiMethod != ''">
                AND api_method = #{apiMethod}
            </if>
        </where>
        order by id desc
    </select>

    <insert id="insertCrmApiInfo">
        <selectKey keyProperty="id" order="BEFORE" resultType="long">
            select seq_crm_api_info.nextval as id from DUAL
        </selectKey>
        insert into crm_api_info (
            id, api_name, api_desc, api_url, api_method, request_example, response_example,
            status, create_by, create_time
        ) values (
            #{id}, #{apiName}, #{apiDesc}, #{apiUrl}, #{apiMethod}, #{requestExample}, #{responseExample},
            #{status}, #{createBy}, sysdate
        )
    </insert>

    <update id="updateCrmApiInfo">
        update crm_api_info
        <set>
            <if test="apiName != null and apiName != ''">api_name = #{apiName},</if>
            <if test="apiDesc != null">api_desc = #{apiDesc},</if>
            <if test="apiUrl != null and apiUrl != ''">api_url = #{apiUrl},</if>
            <if test="apiMethod != null and apiMethod != ''">api_method = #{apiMethod},</if>
            <if test="requestExample != null">request_example = #{requestExample},</if>
            <if test="responseExample != null">response_example = #{responseExample},</if>
            <if test="status != null">status = #{status},</if>
            update_time = sysdate
        </set>
        where id = #{id}
    </update>

    <update id="updateStatus">
        update crm_api_info set status = #{status}, update_time = sysdate where id = #{id}
    </update>

    <delete id="deleteCrmApiInfoByIds">
        delete from crm_api_info where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
